{
  "name": "proto-circle",
  "version": "0.1.0",
  "description": "Hackathon prototype: instant attribution + USDC micropayments for creator-driven traffic on Arc Testnet.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "lsof -ti:3001 | xargs -I{} kill -9 {} 2>/dev/null || true",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "setup": "node --env-file=.env --import=tsx scripts/create-wallet.ts",
    "fetch-wallets": "node --env-file=.env --import=tsx scripts/fetch-wallets.ts",
    "provision-creator-wallet": "node --env-file=.env --import=tsx scripts/provision-creator-wallet.ts",
    "test-live-payout": "node --env-file=.env --import=tsx scripts/test-live-payout.ts",
    "lint": "next lint"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.3.0",
    "@google/genai": "^1.50.1",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.4.2",
    "nanoid": "^5.0.9",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
