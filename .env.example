# Circle API credentials — get from https://console.circle.com
CIRCLE_API_KEY=TEST_API_KEY:your-key-here

# Generated by `npm run setup` — do not set manually
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_ADDRESS=
CIRCLE_WALLET_BLOCKCHAIN=ARC-TESTNET

# App config
APP_BASE_URL=http://localhost:3000

# Attribution tuning
ATTRIBUTION_WINDOW_DAYS=7
DEFAULT_CONVERSION_USD=5
